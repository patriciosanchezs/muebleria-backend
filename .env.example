# Variables de Entorno para Render
# ⚠️ NO COMMITEAR ESTE ARCHIVO CON VALORES REALES

# MongoDB Connection
MONGODB_URL=mongodb+srv://usuario:password@cluster.mongodb.net/furniture_store?retryWrites=true&w=majority

# JWT Configuration
# Genera un secreto seguro con: openssl rand -base64 64
JWT_SECRET=tu-secret-super-seguro-de-al-menos-256-bits-generado-con-openssl

# JWT Token expiration in milliseconds (default: 24 hours)
JWT_EXPIRATION=86400000

# Spring Profile (prod para producción)
SPRING_PROFILES_ACTIVE=prod

# Server Port (Render lo asigna automáticamente, pero Spring Boot usa 8080 internamente)
PORT=8080

# ============================================
# INSTRUCCIONES
# ============================================
# 
# 1. MongoDB Atlas:
#    - Crear cuenta en https://www.mongodb.com/cloud/atlas
#    - Crear un cluster (Free tier disponible)
#    - Database Access: Crear usuario con permisos readWrite
#    - Network Access: Agregar 0.0.0.0/0 (permite desde cualquier IP)
#    - Obtener connection string y reemplazar <password> con tu contraseña
#
# 2. JWT Secret:
#    Linux/Mac/Git Bash:
#      openssl rand -base64 64
#    
#    PowerShell:
#      $bytes = New-Object byte[] 64; [Security.Cryptography.RNGCryptoServiceProvider]::Create().GetBytes($bytes); [Convert]::ToBase64String($bytes)
#
# 3. En Render:
#    - Ir a tu Web Service → Environment
#    - Agregar cada variable con su valor
#    - NO uses comillas alrededor de los valores
#    - Render reiniciará automáticamente al cambiar variables
#
